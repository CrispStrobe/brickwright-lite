{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Brickwright",
  "version": "0.1.0",
  "identifier": "com.crispstrobe.brickwright",
  "build": {
    "frontendDist": "../../../packages/scratch-gui/build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Brickwright",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["sb3"],
        "name": "Scratch 3 Project",
        "description": "Scratch / TurboWarp project",
        "role": "Editor",
        "mimeType": "application/x.scratch.sb3"
      },
      {
        "ext": ["sb2"],
        "name": "Scratch 2 Project",
        "description": "Scratch 2 project",
        "role": "Editor",
        "mimeType": "application/x.scratch.sb2"
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["turbowarp", "brickwright"]
      },
      "mobile": [
        {
          "host": "brickwright.vercel.app",
          "pathPrefix": ["/"]
        }
      ]
    }
  }
}
